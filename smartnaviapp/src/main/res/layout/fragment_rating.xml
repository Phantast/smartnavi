<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true"
    android:focusable="true"
    tools:context=".fragments.RatingFragment">

    <androidx.cardview.widget.CardView
        android:id="@+id/ratingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        app:cardBackgroundColor="#FF222222"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingTop="28dp"
            android:paddingRight="24dp"
            android:paddingBottom="20dp">

            <!-- Title -->
            <TextView
                android:id="@+id/appRateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/tx_34"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Green accent divider -->
            <View
                android:id="@+id/appRateLine"
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="18dp"
                android:background="#86b530" />

            <!-- Description -->
            <TextView
                android:id="@+id/appRateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/tx_31"
                android:textColor="#CCCCCC"
                android:textSize="15sp" />

            <!-- Stars -->
            <ImageView
                android:id="@+id/stars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:contentDescription="@string/tx_34"
                android:focusable="true"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:src="@drawable/stars" />

            <!-- Rate now button (primary green) -->
            <Button
                android:id="@+id/rateButton2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/button_rating_primary"
                android:text="@string/tx_40"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Not now button (subtle) -->
            <Button
                android:id="@+id/rateButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_rating_secondary"
                android:text="@string/tx_39"
                android:textAllCaps="false"
                android:textColor="#999999"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
